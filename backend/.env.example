# OtagWork Backend — Ortam Değişkenleri
# Bu dosyayı `.env` olarak kopyalayın ve değerleri doldurun.
# `.env` git'e gönderilmez (gitignore'da).

# ── Flask ──────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production

# ── Google Gemini AI ───────────────────────────────────────────
# Timesheet AI Yorumu için. Anahtar yoksa AI butonu graceful hata döner.
# 1. https://aistudio.google.com/apikey adresine git
# 2. "Create API key" → kopyala
# 3. Aşağıya yapıştır
GEMINI_API_KEY=AIzaSyCkuk2gB3lzHnZOZyYHfJSz1LqizXaz1xM

# ── SMTP (Şifre sıfırlama maili için, opsiyonel) ──────────────
# Boş bırakılırsa e-postalar console'a düşer (dev modu).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@otagwork.local
SMTP_USE_TLS=true

# ── Frontend URL ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
